#!/bin/sh

# Get list of staged files before running check
STAGED_FILES=$(git diff --cached --name-only)

# Run scoped check (formatting, linting, and type checking)
# Only check packages we publish; upstream test files have stale model refs.
echo "Running formatting, linting, and type checking..."
npx biome check --write --error-on-warnings packages/tui packages/ai packages/agent packages/coding-agent \
  && npx tsgo -p packages/tui/tsconfig.build.json --noEmit \
  && npx tsgo -p packages/ai/tsconfig.build.json --noEmit \
  && npx tsgo -p packages/agent/tsconfig.build.json --noEmit \
  && npx tsgo -p packages/coding-agent/tsconfig.build.json --noEmit
if [ $? -ne 0 ]; then
  echo "❌ Checks failed. Please fix the errors before committing."
  exit 1
fi

# Restage files that were previously staged and may have been modified by formatting
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

echo "✅ All pre-commit checks passed!"
